{
  "name": "@stackline/angular-multiselect-dropdown",
  "version": "22.0.0",
  "scripts": {
    "ng": "ng",
    "start": "cd docs-src/angular-22 && npm start",
    "build": "npm run build-package",
    "test": "ng test",
    "lint": "ng lint",
    "docs:sync": "node scripts/sync-doc-lines.mjs",
    "build-sass": "npx sass --load-path=scss projects/@stackline/angular-multiselect-dropdown-lib/themes/default.theme.scss:projects/@stackline/angular-multiselect-dropdown-lib/themes/default.theme.css projects/@stackline/angular-multiselect-dropdown-lib/themes/custom.theme.scss:projects/@stackline/angular-multiselect-dropdown-lib/themes/custom.theme.css",
    "build-package:raw": "npm run build-sass && npx ng-packagr -p projects/@stackline/angular-multiselect-dropdown-lib/ng-package.json -c projects/@stackline/angular-multiselect-dropdown-lib/tsconfig.lib.json && node scripts/prune-package-artifacts.mjs",
    "build-package": "node scripts/release-line.mjs",
    "build-package:line": "node scripts/release-line.mjs",
    "build:docs": "npm run build:docs:angular-22",
    "github-pages": "npm run build:docs",
    "publish-npm": "node scripts/release-line.mjs --publish",
    "publish-npm:line": "node scripts/release-line.mjs --publish",
    "docs:install:angular-22": "cd docs-src/angular-22 && npm install --ignore-scripts",
    "build:docs:angular-22": "cd docs-src/angular-22 && npm run build"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "22.0.0",
    "@angular/compiler": "22.0.0",
    "@angular/core": ">=22.0.0 <23.0.0",
    "@angular/forms": "22.0.0",
    "@angular/platform-browser": "22.0.0",
    "@angular/platform-browser-dynamic": "22.0.0",
    "@angular/router": "22.0.0",
    "bootstrap": "^5.3.8",
    "rxjs": "~7.8.0",
    "tslib": "^2.5.0",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "22.0.0",
    "@angular/cli": "22.0.0",
    "@angular/compiler-cli": "22.0.0",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^22.0.0",
    "jasmine-core": "~5.1.0",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "~6.4.1",
    "karma-chrome-launcher": "~3.1.1",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.0.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "ng-packagr": "22.0.0",
    "sass": "^1.83.0",
    "typescript": "6.0.3"
  },
  "description": "Angular multiselect dropdown for Angular 22 with maintained release lines, accessibility-focused and keyboard/ARIA tested interactions, dialog-safe body overlays, Stackline skins, search, grouping, templates, headless helpers, and forms support.",
  "homepage": "https://alexandro.net/docs/angular/multiselect/",
  "peerDependencies": {
    "@angular/core": ">=22.0.0 <23.0.0"
  }
}
